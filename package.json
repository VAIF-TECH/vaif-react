{
  "name": "@vaif/react",
  "version": "0.1.0",
  "description": "React hooks for VAIF - Authentication, Data, Realtime, Storage, and more",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "tsc --noEmit",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@vaiftech/client": "^1.5.7",
    "@vaiftech/auth": "^1.5.7"
  },
  "peerDependencies": {
    "react": ">=18.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "react": "^18.2.0",
    "tsup": "^8.5.1",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=19.0.0"
  },
  "keywords": [
    "vaif",
    "react",
    "hooks",
    "authentication",
    "realtime",
    "database",
    "storage",
    "baas"
  ],
  "author": "VAIF Technologies",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/VAIF-TECH/vaif-react.git"
  },
  "bugs": {
    "url": "https://github.com/VAIF-TECH/vaif-react/issues"
  },
  "homepage": "https://docs.vaif.studio",
  "publishConfig": {
    "access": "public"
  }
}
